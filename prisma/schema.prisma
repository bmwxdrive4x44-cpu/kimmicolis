// This is your Prisma schema file for PostgreSQL (Vercel, Neon, Supabase)
// Use this file for production deployment

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

// Users table - all user types
model User {
  id            String   @id @default(cuid())
  email         String   @unique
  password      String?
  name          String
  firstName     String?
  lastName      String?
  address       String?
  role          String   // "CLIENT", "TRANSPORTER", "RELAIS", "ENSEIGNE", "ADMIN"
  phone         String?
  siret         String?  // For transporters
  image         String?
  isActive      Boolean  @default(true)
  clientType    String   @default("STANDARD") // STANDARD | PRO
  eligibleProImplicit Boolean @default(false)
  eligibleProSince  DateTime?
  proLastEvaluatedAt DateTime?
  weeklyValidShipments Int @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  // Relations
  parcelsAsClient     Colis[]         @relation("ClientParcels")
  trajets             Trajet[]        @relation("TransporterTrajets")
  missions            Mission[]       @relation("TransporterMissions")
  relais              Relais?         @relation("UserRelais")
  enseigne            Enseigne?       @relation("UserEnseigne")
  transporterApplication TransporterApplication? @relation("UserTransporterApplication")
  transporterPreferences TransporterPreferences? @relation("UserTransporterPreferences")
  payments            Payment[]
  notifications       Notification[]
  passwordResetTokens PasswordResetToken[]
  disputesOpened      Dispute[]  @relation("DisputesOpened")
  disputesResolved    Dispute[]  @relation("DisputesResolved")
}

model Enseigne {
  id              String   @id @default(cuid())
  userId          String   @unique
  businessName    String
  legalName       String?
  website         String?
  logoUrl         String?
  monthlyVolume   Int      @default(0)
  billingEmail    String?
  operationalCity String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation("UserEnseigne", fields: [userId], references: [id])

  @@index([businessName])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String
  message   String
  isRead    Boolean  @default(false)
  repliedAt    DateTime?
  replyContent String?
  createdAt    DateTime  @default(now())

  @@index([createdAt])
  @@index([isRead])
}

// Relay points
model Relais {
  id               String   @id @default(cuid())
  userId           String   @unique
  commerceName     String
  address          String
  ville            String
  openTime         String?
  closeTime        String?
  latitude         Float?
  longitude        Float?
  photos           String?  // JSON array of photo URLs
  commissionPetit  Float    @default(100)
  commissionMoyen  Float    @default(200)
  commissionGros   Float    @default(300)
  status           String   @default("PENDING") // PENDING, APPROVED, REJECTED (approval status)
  operationalStatus String  @default("ACTIF") // ACTIF, SUSPENDU (operational status)
  suspensionReason String?  // Reason for suspension if SUSPENDU
  suspendedAt      DateTime? // When suspended
  cashCollected    Float    @default(0)  // Total cash collected from clients
  cashReversed     Float    @default(0)  // Total reversed to platform
  
  // Compliance & security fields
  cautionAmount     Float?               // Caution amount (virtual or real SEPA block)
  cautionStatus     String   @default("PENDING") // PENDING, BLOCKED, PARTIAL_RELEASED, FULLY_RELEASED, FORFEITED
  cautionPaidAt     DateTime?
  activationDate    DateTime?            // When relais became active
  firstActivityDate DateTime?            // When relais first got deliveries
  complianceScore   Float    @default(100) // Score 0-100, decreases with violations
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  
  user             User     @relation("UserRelais", fields: [userId], references: [id])
  parcelsDepart    Colis[]  @relation("RelaisDepart")
  parcelsArrivee   Colis[]  @relation("RelaisArrivee")
  cashTransactions RelaisCash[]
  cashPickups      CashPickup[]
  sanctions        RelaisSanction[]
  audits           RelaisAudit[]
}

// Transporter applications
model TransporterApplication {
  id              String   @id @default(cuid())
  userId          String   @unique
  fullName        String
  phone           String
  vehicle         String
  license         String
  experience      Int
  regions         String   // JSON array of regions
  description     String?
  status          String   @default("PENDING") // PENDING, APPROVED, REJECTED
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  user            User     @relation("UserTransporterApplication", fields: [userId], references: [id])
}

// Transporter preferences for intelligent auto-assignment
model TransporterPreferences {
  id                    String   @id @default(cuid())
  userId                String   @unique
  
  // Preferred cities/routes (JSON array)
  preferredCities       String?  // JSON array of preferred departure/arrival cities
  preferredRoutes       String?  // JSON array of preferred routes {villeDepart, villeArrivee}
  excludedCities        String?  // JSON array of cities to avoid
  
  // Assignment preferences
  autoAssignEnabled     Boolean  @default(false) // Enable auto-assignment
  autoAssignSchedule    String?  // CRON expression or predefined schedule (DAILY_8AM, WEEKLY, MANUAL)
  maxDailyMissions      Int      @default(10) // Maximum missions per day
  maxActiveParallel     Int      @default(5)  // Max concurrent active missions
  
  // Parcel preferences
  maxWeightKg           Float?   // Maximum weight accepted (kg)
  maxDimensionCm        Float?   // Maximum dimension (cm) 
  acceptsCOD            Boolean  @default(true) // Accept cash-on-delivery
  acceptsPriority       Boolean  @default(true) // Accept priority parcels
  acceptsBulk           Boolean  @default(false) // Accept bulk shipments
  
  // Scoring preferences (weights 0-100)
  scoreWeightDistance   Int      @default(30)  // Priority: route distance
  scoreWeightCapacity   Int      @default(25)  // Priority: available capacity
  scoreWeightTiming     Int      @default(20)  // Priority: departure timing
  scoreWeightEarnings   Int      @default(25)  // Priority: earnings potential
  
  // Availability windows (JSON)
  availabilityWindows   String?  // JSON array of {dayOfWeek, startTime, endTime}
  
  // Learning data
  lastAssignmentCheck   DateTime? // Last time auto-assign was triggered
  successRate           Float    @default(100) // Completion success rate (%)
  avgRating             Float?   // Average customer rating
  
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  
  user                 User     @relation("UserTransporterPreferences", fields: [userId], references: [id])
}

// Transport lines with pricing
model Ligne {
  id              String   @id @default(cuid())
  villeDepart     String
  villeArrivee    String
  tarifPetit      Float
  tarifMoyen      Float
  tarifGros       Float
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  colis           Colis[]
  trajets         Trajet[]
}

// Parcels/Packages
model Colis {
  id              String   @id @default(cuid())
  trackingNumber  String   @unique
  clientId        String
  lineId          String?
  senderFirstName String?
  senderLastName  String?
  senderPhone     String?
  recipientFirstName String?
  recipientLastName  String?
  recipientPhone     String?
  withdrawalCodeHash String?
  relaisDepartId  String
  relaisArriveeId String
  villeDepart     String
  villeArrivee    String
  weight          Float?
  description     String?
  prixClient      Float
  commissionPlateforme Float
  commissionRelais Float
  netTransporteur Float
  status          String   @default("CREATED") // CREATED | PENDING_PAYMENT | PAID | READY_FOR_DEPOSIT | PAID_RELAY | DEPOSITED_RELAY | RECU_RELAIS | WAITING_PICKUP | EN_TRANSPORT | ARRIVE_RELAIS_DESTINATION | LIVRE | ANNULE | RETOUR | EN_DISPUTE | REFUSE_RELAIS | COLIS_PERDU | COLIS_ENDOMMAGE | ABSENT_DESTINATAIRE
  qrCode          String   // QR code data
  qrToken         String?  @unique // token sécurisé embarqué dans le QR (anti-replay)
  custody         String   @default("CLIENT") // CLIENT | RELAIS_DEPART | TRANSPORTEUR | RELAIS_DEST
  qrCodeImage     String?  // QR code image URL
  photoProof      String?  // JSON array of proof photo URLs
  isPriority      Boolean  @default(false) // true for pro client parcels
  dateCreation    DateTime @default(now())
  dateLimit       DateTime?
  expectedDeliveryAt DateTime? // date cible SLA
  delayed         Boolean  @default(false)   // true si SLA dépassé
  deliveredAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  client          User     @relation("ClientParcels", fields: [clientId], references: [id])
  line            Ligne?   @relation(fields: [lineId], references: [id])
  relaisDepart    Relais   @relation("RelaisDepart", fields: [relaisDepartId], references: [id])
  relaisArrivee   Relais   @relation("RelaisArrivee", fields: [relaisArriveeId], references: [id])
  missions        Mission[]
  payments        Payment[]
  trackingHistory TrackingHistory[]
  relaisCash      RelaisCash[]
  disputes        Dispute[]
  deliveryProof   DeliveryProof?
}

model Payment {
  id             String   @id
  colisId        String
  clientId       String
  amount         Float
  currency       String   @default("DZD")
  status         String   @default("PENDING") // PENDING | PROCESSING | COMPLETED | FAILED | REFUNDED
  method         String?
  transactionRef String?  @unique
  errorMessage   String?
  processedAt    DateTime?
  expiresAt      DateTime
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  colis          Colis    @relation(fields: [colisId], references: [id])
  client         User     @relation(fields: [clientId], references: [id])

  @@index([clientId, createdAt])
  @@index([colisId, createdAt])
  @@index([status, createdAt])
}

// Transporter trips/routes
model Trajet {
  id              String   @id @default(cuid())
  transporteurId  String
  lineId          String?
  villeDepart     String
  villeArrivee    String
  villesEtapes    String?  // JSON array of intermediate cities
  dateDepart      DateTime
  placesColis     Int      @default(10)
  placesUtilisees Int      @default(0)
  status          String   @default("PROGRAMME") // PROGRAMME, EN_COURS, TERMINE, ANNULE
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  transporteur    User     @relation("TransporterTrajets", fields: [transporteurId], references: [id])
  line            Ligne?   @relation(fields: [lineId], references: [id])
  missions        Mission[]
}

// Missions (parcel assigned to transporter)
model Mission {
  id              String   @id @default(cuid())
  colisId         String
  transporteurId  String
  trajetId        String?
  status          String   @default("ASSIGNE") // ASSIGNE, EN_COURS, LIVRE
  assignedAt      DateTime @default(now())
  completedAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  colis           Colis    @relation(fields: [colisId], references: [id])
  transporteur    User     @relation("TransporterMissions", fields: [transporteurId], references: [id])
  trajet          Trajet?  @relation(fields: [trajetId], references: [id])
}

// Tracking history
model TrackingHistory {
  id          String   @id @default(cuid())
  colisId     String
  status      String
  location    String?
  notes       String?
  createdAt   DateTime @default(now())
  userId      String?  // acteur qui a déclenché la transition
  relaisId    String?  // relais concerné si applicable
  
  colis       Colis    @relation(fields: [colisId], references: [id])
}

// Notifications
model Notification {
  id          String   @id @default(cuid())
  userId      String
  title       String
  message     String
  type        String   // EMAIL, SMS, IN_APP
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())
  
  user        User     @relation(fields: [userId], references: [id])
}

// Platform settings
model Setting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  updatedAt   DateTime @updatedAt
}

// Transporter wallet - pending vs available earnings
model TransporterWallet {
  id                String   @id @default(cuid())
  transporteurId    String   @unique
  pendingEarnings   Float    @default(0)  // En attente (colis en cours)
  availableEarnings Float    @default(0)  // Disponibles au retrait
  totalEarned       Float    @default(0)  // Total historique gagné
  totalWithdrawn    Float    @default(0)  // Total retiré
  updatedAt         DateTime @updatedAt
  createdAt         DateTime @default(now())
}

// Relay cash ledger - track cash collected vs reversed
model RelaisCash {
  id             String   @id @default(cuid())
  relaisId       String
  colisId        String
  amount         Float    // Cash amount collected from client
  type           String   // COLLECTED | REVERSED
  
  // Audit fields
  declaredAmount    Float?   // Amount declared by relais
  verifiedAmount    Float?   // Amount verified by auditor
  variancePercent   Float?   // (declared - verified) / verified * 100
  auditDate         DateTime?
  auditedBy         String?  // Admin user ID who audited
  
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  relais         Relais   @relation(fields: [relaisId], references: [id])
  colis          Colis    @relation(fields: [colisId], references: [id])
  
  @@index([relaisId, createdAt])
  @@index([auditedBy])
}

// Dispute / Litige model
model Dispute {
  id           String   @id @default(cuid())
  colisId      String
  openedById   String
  reason       String   // LOST | DAMAGED | DELAYED | WRONG_ADDRESS | OTHER
  description  String
  status       String   @default("OPEN") // OPEN | UNDER_REVIEW | RESOLVED | CLOSED
  resolution   String?
  resolvedById String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  colis        Colis    @relation(fields: [colisId], references: [id])
  openedBy     User     @relation("DisputesOpened", fields: [openedById], references: [id])
  resolvedBy   User?    @relation("DisputesResolved", fields: [resolvedById], references: [id])

  @@index([colisId])
  @@index([openedById])
  @@index([status])
}

// Relay sanctions & compliance violations
model RelaisSanction {
  id          String   @id @default(cuid())
  relaisId    String
  reason      String   // NON_REVERSAL | HIGH_VARIANCE | MISSING_AUDIT | OPERATOR_ERROR | OTHER
  type        String   // REDUCTION_VOLUME | SUSPENSION | CAUTION_FORFEIT | WARNING
  reduction   Float?   // If volume reduction: percentage (0-100)
  startDate   DateTime @default(now())
  endDate     DateTime?
  appliedBy   String   // Admin user ID
  notes       String?
  createdAt   DateTime @default(now())
  
  relais      Relais   @relation(fields: [relaisId], references: [id])
  
  @@index([relaisId, startDate])
  @@index([endDate])
}

// Immutable audit log for relais monthly compliance
model RelaisAudit {
  id            String   @id @default(cuid())
  relaisId      String
  auditDate     DateTime @default(now())
  declaredTotal Float    // Total cash relais declared
  verifiedTotal Float    // Total cash actually verified
  variance      Float    // Percentage variance
  discrepancies Int      @default(0) // Number of variance discrepancies found
  status        String   @default("PENDING") // PENDING | COMPLETED | FLAGGED
  auditedBy     String   // Admin user ID
  notes         String?
  createdAt     DateTime @default(now())
  // Immutable - no updatedAt
  
  relais        Relais   @relation(fields: [relaisId], references: [id])
  
  @@index([relaisId, auditDate])
  @@index([status])
}

// Action log for anti-fraud audit trail
model ActionLog {
  id          String   @id @default(cuid())
  eventId     String?  @unique // clé idempotence (webhook/scan/livraison)
  scope       String?  // PAYMENT | QR | DELIVERY
  userId      String?  // Who performed the action
  entityType  String   // COLIS | RELAIS | TRANSPORTER | USER
  entityId    String
  action      String   // QR_SCAN | PAYMENT_VALIDATE | STATUS_CHANGE | LOGIN | etc.
  details     String?  // JSON string with extra info
  ipAddress   String?
  createdAt   DateTime @default(now())

  @@index([entityType, entityId, action])
}

model DeliveryProof {
  id            String   @id @default(cuid())
  colisId       String   @unique
  receiverName  String
  codeVerified  Boolean  @default(true)
  photoUrl      String?
  relaisId      String?
  deliveredById String?
  createdAt     DateTime @default(now())

  colis         Colis    @relation(fields: [colisId], references: [id])
}

// Physical cash pickup from relay to platform
model CashPickup {
  id                      String   @id @default(cuid())
  relaisId                String
  collectorId             String?
  expectedAmount          Float
  collectedAmount         Float?
  status                  String   @default("REQUESTED") // REQUESTED | ASSIGNED | IN_PROGRESS | CONFIRMED | DISPUTED | CANCELLED
  scheduledAt             DateTime?
  startedAt               DateTime?
  confirmedAt             DateTime?
  receiptRef              String?  @unique
  relayValidationCodeHash String?
  collectorCodeHash       String?
  proofPhotoUrl           String?
  notes                   String?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  relais                  Relais   @relation(fields: [relaisId], references: [id])

  @@index([relaisId, createdAt])
  @@index([status, scheduledAt])
}
